{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "services": {
    "web": {
      "root": "apps/web",
      "framework": "nextjs"
    },
    "mfp": {
      "root": "services/mfp",
      "framework": "fastapi",
      "entrypoint": "fitness_mfp.api:app"
    }
  },
  "rewrites": [
    {
      "source": "/api/mfp/(.*)",
      "destination": {
        "service": "mfp"
      }
    },
    {
      "source": "/api/mfp",
      "destination": {
        "service": "mfp"
      }
    },
    {
      "source": "/(.*)",
      "destination": {
        "service": "web"
      }
    }
  ],
  "crons": [
    {
      "path": "/api/cron/daily-sync",
      "schedule": "30 6 * * *"
    }
  ]
}
